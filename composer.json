{
  "name": "qburst/customer-engagement-notification-bundle",
  "description": "Customer Engagement Notification Bundle for Pimcore — provides multi-channel notification delivery including email, SMS, push, LINE, WhatsApp, plus campaign orchestration, segmentation, and security-hardened messaging.",
  "license": "GPL-3.0-or-later",
  "type": "pimcore-bundle",
  "keywords": [
    "pimcore",
    "notification",
    "email",
    "sms",
    "push",
    "line",
    "whatsapp",
    "customer",
    "engagement",
    "crm",
    "marketing"
  ],
  "require": {
    "php": "~8.1.0 || ~8.2.0 || ~8.3.0",
    "pimcore/pimcore": "^11.2",
    "symfony/config": "^6.2",
    "symfony/dependency-injection": "^6.2",
    "symfony/http-foundation": "^6.3",
    "symfony/http-kernel": "^6.2",
    "symfony/mailer": "^6.4|^7.0",
    "symfony/mime": "^6.4|^7.0",
    "symfony/routing": "^6.2",
    "symfony/yaml": "^6.2",
    "symfony/http-client": "^6.4|^7.0",
    "symfony/cache": "^6.4|^7.0",
    "psr/log": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "CustomerEngagementNotificationBundle\\": "src/"
    },
    "exclude-from-classmap": [
      "frontend/",
      "install/",
      "doc/"
    ]
  },
  "extra": {
    "pimcore": {
      "bundles": [
        "CustomerEngagementNotificationBundle\\CustomerEngagementNotificationBundle"
      ]
    }
  }
}
